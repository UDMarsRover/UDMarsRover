<?xml version="1.0"?>
<robot name="turret_arm">

  <!-- ================= BASE ================= -->
  <link name="base_link"/>

  <!-- ================= TURRET ================= -->
  <link name="turret_link">
    <visual>
      <geometry>
        <cylinder radius="0.1" length="0.1"/>
      </geometry>
      <origin xyz="0 0 0.05"/>
    </visual>
  </link>

  <joint name="turret_joint" type="revolute">
    <parent link="base_link"/>
    <child link="turret_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <!-- Rotation in x-y plane => about z-axis -->
    <axis xyz="0 0 1"/>
    <!-- 180 degrees total: from -90 to +90 -->
    <limit lower="-1.5708" upper="1.5708" effort="10" velocity="1"/>
  </joint>

  <!-- ================= SHOULDER ================= -->
  <link name="shoulder_link">
    <visual>
      <geometry>
        <cylinder radius="0.05" length="0.4572"/>
      </geometry>
      <!-- Oriented along x-axis -->
      <origin xyz="0.2286 0 0" rpy="0 1.5708 0"/>
    </visual>
  </link>

  <joint name="shoulder_joint" type="revolute">
    <parent link="turret_link"/>
    <child link="shoulder_link"/>
    <origin xyz="0 0 0.1" rpy="0 0 0"/>
    <!-- Rotates in vertical plane (z-plane relative motion) -->
    <axis xyz="0 1 0"/>
    <limit lower="-1.5708" upper="1.5708" effort="10" velocity="1"/>
  </joint>

  <!-- ================= ELBOW ================= -->
  <link name="elbow_link">
    <visual>
      <geometry>
        <cylinder radius="0.04" length="0.4572"/>
      </geometry>
      <!-- Oriented along x-axis -->
      <origin xyz="0.2286 0 0" rpy="0 1.5708 0"/>
    </visual>
  </link>

  <joint name="elbow_joint" type="revolute">
    <parent link="shoulder_link"/>
    <child link="elbow_link"/>
    <origin xyz="0.4572 0 0" rpy="0 0 0"/>
    <!-- Same plane as shoulder -->
    <axis xyz="0 1 0"/>
    <limit lower="-1.5708" upper="1.5708" effort="10" velocity="1"/>
  </joint>

  <!-- ================= WRIST ================= -->
  <link name="wrist_link">
    <visual>
      <geometry>
        <cylinder radius="0.03" length="0.1"/>
      </geometry>
      <origin xyz="0.05 0 0" rpy="0 1.5708 0"/>
    </visual>
  </link>

  <joint name="wrist_joint" type="revolute">
    <parent link="elbow_link"/>
    <child link="wrist_link"/>
    <origin xyz="0.4572 0 0" rpy="0 0 0"/>
    <!-- Twist perpendicular to arm (along x-axis) -->
    <axis xyz="1 0 0"/>
    <limit lower="-3.1416" upper="3.1416" effort="5" velocity="2"/>
  </joint>

</robot>
